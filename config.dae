    domain(geosite:youtube,
        geosite:instagram,
        geosite:telegram,
        geosite:whatsapp,
        geosite:viber,
        geosite:twitter,
        geosite:discord,
        geosite:twitch,
        geosite:rutracker,
        geosite:category-media-ru,
        geosite:category-web-archive,
        geosite:category-ipfs,
        geosite:category-porn,
        geosite:libgen,
        geosite:category-anticensorship,
        geosite:category-proxy-tunnels,
        geosite:category-vpnservices,
        geosite:category-pt,
        geosite:category-public-tracker,
        geosite:category-android-app-download
    ) -> proxy_group
    domain(geosite:category-ai-!cn,
        geosite:soundcloud,
        geosite:gog
    ) -> proxy_group
    domain(suffix: stripe.com,
        geosite:paypal,
        geosite:category-cryptocurrency,
    ) -> proxy_group
    domain(geosite:category-ddns) -> proxy_group

    fallback: direct
}
